{
  "name": "gata-language-server",
  "version": "0.1.0",
  "private": true,
  "description": "Syntax + semantic diagnostics for the Gata language, backing the gata-highlighting VS Code extension.",
  "main": "dist/server.js",
  "scripts": {
    "build": "esbuild src/server.ts --bundle --platform=node --outfile=dist/server.js --external:vscode",
    "watch": "npm run build -- --watch"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0"
  }
}
